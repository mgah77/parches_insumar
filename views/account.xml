<odoo>


    <record model="ir.ui.view" id="view_account_inherit_form">
        <field name="name">account.parche.inherit.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="l10n_cl_fe.view_invoice_form"/>
        <field name="arch" type="xml">
             <xpath expr="//form" position="attributes">
                <attribute name="duplicate">false</attribute>
            </xpath>
            <xpath expr="//field[@name='acteco_id']" position="attributes">
                <attribute name="string">Actividad económica</attribute>
            </xpath>
            <field name="acteco_id" position="after">
                <field name="glosa"/>
            </field>           
        </field>
    </record>
    <record model="ir.ui.view" id="view_account_inherit_tree">
        <field name="name">account.parche.inherit.tree</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="l10n_cl_fe.invoice_tree"/>
        <field name="arch" type="xml">
            
            <xpath expr="//field[@name='amount_untaxed_signed']" position="attributes">
                <attribute name="string">Neto</attribute>
            </xpath>
            <xpath expr="//field[@name='amount_untaxed_signed']" position="after">
                <field name="amount_tax_signed"/>
            </xpath>
            <xpath expr="//field[@name='invoice_date']" position="before">
                <field name="glosa"/>
            </xpath>
            
            <xpath expr="//field[@name='amount_tax_signed']" position="attributes">
                <attribute name="string">IVA</attribute>
            </xpath>
            <xpath expr="//field[@name='sii_document_number']" position="attributes">
                <attribute name="string">Numero</attribute>
            </xpath>
            <xpath expr="//field[@name='amount_total_in_currency_signed']" position="replace">               
            </xpath>
            <xpath expr="//field[@name='activity_ids']" position="replace">               
            </xpath>

            </field>
    </record>

    <record id="account_move_search_custom" model="ir.ui.view">
        <field name="name">account.move.search.glosa.prioritaria</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="l10n_cl_fe.view_account_invoice_filter"/>
        <field name="arch" type="xml">
        <xpath expr="//search/field[1]" position="before">
            <field name="glosa" string="Glosa"/>
        </xpath>
        </field>
    </record>  

       <!-- Acción para restringir la vista del boton para volver a borrador --> 
    <record id="restrict_button_draft_to_admin" model="ir.ui.view">
        <field name="name">account.move.form.restrict.draft</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">            
            <!-- Ubicamos el botón button_draft -->
            <button name="button_draft" position="attributes">
                <!-- Establecemos que solo el grupo group_admin pueda verlo -->
                <attribute name="groups">parches_insumar.group_admin</attribute>
            </button>
            
        </field>
    </record>

        <!-- ........................ -->
        <!-- Coreccion de facturas -->
        <!-- .......................... -->

    <data noupdate="1">
        <record id="seq_account_move_amount_fix" model="ir.sequence">
            <field name="name">Corrección de Montos</field>
            <field name="code">account.move.amount.fix</field>
            <field name="prefix">COR/%(year)s/</field>
            <field name="padding">4</field>
        </record>
    </data>

    <!-- Vista Formulario -->
    <record id="view_account_move_amount_fix_form" model="ir.ui.view">
        <field name="name">account.move.amount.fix.form</field>
        <field name="model">account.move.amount.fix</field>
        <field name="arch" type="xml">
            <form string="Corrección de Montos">
                <header>
                    <button name="action_save" string="Grabar Cambios" type="object" 
                            class="oe_highlight" states="draft"/>
                    <button name="action_validate" string="Validar Cambio" type="object" 
                            class="btn-primary" states="saved" confirm="¿Está seguro de aplicar esta corrección? La acción es irreversible."/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Factura Origen">
                            <field name="move_id"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Motivo">
                            <field name="notes" placeholder="Indique el motivo de la corrección..."/>
                        </group>
                    </group>
                    <group>
                        <group string="Valores Actuales en Sistema">
                            <field name="old_amount_untaxed"/>
                            <field name="old_amount_tax"/>
                            <field name="old_amount_total"/>
                            <field name="old_amount_residual"/>
                        </group>
                        <group string="Nuevos Valores a Aplicar">
                            <field name="new_amount_untaxed"/>
                            <field name="new_amount_tax"/>
                            <field name="new_amount_total"/>
                            <field name="new_amount_residual"/>
                        </group>
                    </group>
                    <group string="Auditoría">
                        <group>
                            <field name="saved_by"/>
                            <field name="saved_date"/>
                        </group>
                        <group>
                            <field name="validated_by"/>
                            <field name="validated_date"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vista Lista -->
    <record id="view_account_move_amount_fix_tree" model="ir.ui.view">
        <field name="name">account.move.amount.fix.tree</field>
        <field name="model">account.move.amount.fix</field>
        <field name="arch" type="xml">
            <tree string="Correcciones de Montos" decoration-info="state == 'draft'" decoration-warning="state == 'saved'" decoration-success="state == 'validated'">
                <field name="name"/>
                <field name="move_id"/>
                <field name="old_amount_total"/>
                <field name="new_amount_total"/>
                <field name="saved_by"/>
                <field name="validated_by"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_account_move_amount_fix" model="ir.actions.act_window">
        <field name="name">Correcciones de Montos</field>
        <field name="res_model">account.move.amount.fix</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No hay correcciones de montos registradas</p>
        </field>
    </record>

    <!-- Menú -->
    <menuitem id="menu_account_move_amount_fix" 
              name="Correcciones de Montos" 
              parent="account.menu_finance_entries" 
              action="action_account_move_amount_fix" 
              sequence="40"/>

    <!-- Botón en la factura de proveedor -->
    <record id="view_move_form_fix_button" model="ir.ui.view">
        <field name="name">account.move.form.fix.button</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
                   <!-- 1. Agregar amount_untaxed como campo invisible para que el attrs funcione -->
        <xpath expr="//field[@name='move_type']" position="after">
            <field name="amount_untaxed" invisible="1"/>
        </xpath>

            <xpath expr="//div[@name='button_box']" position="inside">
                <!-- Condición: Solo facturas de proveedor con neto 0 y no en borrador -->
                <button name="action_create_amount_fix" 
                        type="object" 
                        class="oe_stat_button" 
                        icon="fa-pencil-square-o"
                        string="Corregir Montos"
                        attrs="{'invisible': ['|', '|', ('move_type', '!=', 'in_invoice'), ('amount_untaxed', '!=', 0.0), ('state', '=', 'draft')]}"
                        groups="account.group_account_manager"/>
            </xpath>
        </field>
    </record>

</odoo>
