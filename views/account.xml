<odoo>


    <record model="ir.ui.view" id="view_account_inherit_form">
        <field name="name">account.parche.inherit.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="l10n_cl_fe.view_invoice_form"/>
        <field name="arch" type="xml">
             <xpath expr="//form" position="attributes">
                <attribute name="duplicate">false</attribute>
            </xpath>
            <xpath expr="//field[@name='acteco_id']" position="attributes">
                <attribute name="string">Actividad económica</attribute>
            </xpath>
            <field name="acteco_id" position="after">
                <field name="glosa"/>
            </field>           
        </field>
    </record>
    <record model="ir.ui.view" id="view_account_inherit_tree">
        <field name="name">account.parche.inherit.tree</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="l10n_cl_fe.invoice_tree"/>
        <field name="arch" type="xml">
            
            <xpath expr="//field[@name='amount_untaxed_signed']" position="attributes">
                <attribute name="string">Neto</attribute>
            </xpath>
            <xpath expr="//field[@name='amount_untaxed_signed']" position="after">
                <field name="amount_tax_signed"/>
            </xpath>
            <xpath expr="//field[@name='invoice_date']" position="before">
                <field name="glosa"/>
            </xpath>
            
            <xpath expr="//field[@name='amount_tax_signed']" position="attributes">
                <attribute name="string">IVA</attribute>
            </xpath>
            <xpath expr="//field[@name='sii_document_number']" position="attributes">
                <attribute name="string">Numero</attribute>
            </xpath>
            <xpath expr="//field[@name='amount_total_in_currency_signed']" position="replace">               
            </xpath>
            <xpath expr="//field[@name='activity_ids']" position="replace">               
            </xpath>

            </field>
    </record>

    <record id="account_move_search_custom" model="ir.ui.view">
        <field name="name">account.move.search.glosa.prioritaria</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="l10n_cl_fe.view_account_invoice_filter"/>
        <field name="arch" type="xml">
        <xpath expr="//search/field[1]" position="before">
            <field name="glosa" string="Glosa"/>
        </xpath>
        </field>
    </record>  

       <!-- Acción para restringir la vista del boton para volver a borrador --> 
    <record id="restrict_button_draft_to_admin" model="ir.ui.view">
        <field name="name">account.move.form.restrict.draft</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">            
            <!-- Ubicamos el botón button_draft -->
            <button name="button_draft" position="attributes">
                <!-- Establecemos que solo el grupo group_admin pueda verlo -->
                <attribute name="groups">parches_insumar.group_admin</attribute>
            </button>
            
        </field>
    </record>

            <!-- ................................................... -->
             <!-- correccion de valores de facturas preoveedores -->
             <!-- ..................................................... -->


    <record id="view_account_move_tree_amount_fix" model="ir.ui.view">
        <field name="name">account.move.tree.amount.fix</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <tree string="Facturas Proveedor Neto 0">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="invoice_date"/>
                <field name="amount_untaxed"/>
                <field name="amount_tax"/>
                <field name="amount_total"/>
                <field name="amount_residual"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- FORM -->

    <record id="view_account_move_form_amount_fix" model="ir.ui.view">
        <field name="name">account.move.form.amount.fix</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <form string="Corrección de Montos">

                <header>

                    <button name="action_save_changes"
                            type="object"
                            string="Grabar Cambios"
                            class="btn-primary"
                            invisible="x_change_saved"/>

                    <button name="action_validate_changes"
                            type="object"
                            string="Validar Cambio"
                            class="btn-primary"
                            invisible="not x_change_saved or x_change_validated"/>

                </header>

                <sheet>

                    <group>
                        <group string="Factura">
                            <field name="name" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="invoice_date" readonly="1"/>
                        </group>

                        <group string="Auditoría">
                            <field name="create_uid" readonly="1"/>
                            <field name="create_date" readonly="1"/>
                        </group>
                    </group>

                    <separator string="Montos"/>

                    <group col="2">

                        <group string="Valores Actuales">

                            <field name="amount_untaxed" readonly="1"/>
                            <field name="amount_tax" readonly="1"/>
                            <field name="amount_total" readonly="1"/>
                            <field name="amount_residual" readonly="1"/>

                        </group>

                        <group string="Valores Nuevos">

                            <field name="x_new_amount_untaxed"/>
                            <field name="x_new_amount_tax"/>
                            <field name="x_new_amount_total"/>
                            <field name="x_new_amount_residual"/>

                        </group>

                    </group>

                    <separator string="Estado"/>

                    <group>
                        <group>
                            <field name="x_change_saved" readonly="1"/>
                            <field name="x_change_saved_uid" readonly="1"/>
                            <field name="x_change_saved_date" readonly="1"/>
                        </group>

                        <group>
                            <field name="x_change_validated" readonly="1"/>
                            <field name="x_change_validated_uid" readonly="1"/>
                            <field name="x_change_validated_date" readonly="1"/>
                        </group>
                    </group>

                </sheet>

            </form>
        </field>
    </record>

    <!-- ACTION -->

    <record id="action_account_move_amount_fix" model="ir.actions.act_window">
        <field name="name">Corrección de Facturas</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[
            (5,0,0),
            (0,0,{
                'view_mode':'tree',
                'view_id':ref('view_account_move_tree_amount_fix')
            }),
            (0,0,{
                'view_mode':'form',
                'view_id':ref('view_account_move_form_amount_fix')
            })
        ]"/>
        <field name="domain">[
            ('move_type','=','in_invoice'),
            ('amount_untaxed','=',0)
        ]</field>
    </record>

    <!-- MENU -->

<menuitem
    id="menu_account_move_amount_fix"
    name="Corrección de Facturas"
    parent="account.menu_finance_payables"
    action="action_account_move_amount_fix"
    sequence="999"/>


</odoo>
