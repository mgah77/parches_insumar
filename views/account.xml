<odoo>
    <record model="ir.ui.view" id="view_account_inherit_form">
        <field name="name">account.parche.inherit.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="l10n_cl_fe.view_invoice_form"/>
        <field name="arch" type="xml">
             <xpath expr="//form" position="attributes">
                <attribute name="duplicate">false</attribute>
            </xpath>
            <xpath expr="//field[@name='acteco_id']" position="attributes">
                <attribute name="string">Actividad económica</attribute>
            </xpath>
            <field name="acteco_id" position="after">
                <field name="glosa"/>
            </field>           
        </field>
    </record>
    <record model="ir.ui.view" id="view_account_inherit_tree">
        <field name="name">account.parche.inherit.tree</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="l10n_cl_fe.invoice_tree"/>
        <field name="arch" type="xml">
            
            <xpath expr="//field[@name='amount_untaxed_signed']" position="attributes">
                <attribute name="string">Neto</attribute>
            </xpath>
            <xpath expr="//field[@name='amount_untaxed_signed']" position="after">
                <field name="amount_tax_signed"/>
            </xpath>
            <xpath expr="//field[@name='invoice_date']" position="before">
                <field name="glosa"/>
                <field name="company_has_reparos" invisible="1"/>
            </xpath>
            
            <xpath expr="//field[@name='amount_tax_signed']" position="attributes">
                <attribute name="string">IVA</attribute>
            </xpath>
            <xpath expr="//field[@name='sii_document_number']" position="attributes">
                <attribute name="string">Numero</attribute>
            </xpath>
            <xpath expr="//field[@name='amount_total_in_currency_signed']" position="replace">               
            </xpath>
            <xpath expr="//field[@name='activity_ids']" position="replace">               
            </xpath>

             <xpath expr="//tree/field[1]" position="before">
                <header>
                    <button name="%(action_show_reparos)d" 
                            string="REPAROS" 
                            type="action" 
                            />
                </header>
            </xpath>
            </field>
    </record>

    <!-- Heredar la vista tree de facturas directo de account.move >
    <record id="view_move_tree_inherit_reparos" model="ir.ui.view">
        <field name="name">account.move.tree.inherit.reparos</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <! Insertar el campo invisible para usarlo en el botón>
            <! Añadir botón REPAROS antes del botón Crear (NEW) >
            <xpath expr="//tree/header/button[@name='create']" position="before">
                <button name="%(action_show_reparos)d"
                        string="REPAROS"
                        type="action"
                        groups="parches_insumar.group_admin"
                        invisible="not company_has_reparos"/>
            </xpath>
        </field>
    </record-->


    <record id="account_move_search_custom" model="ir.ui.view">
        <field name="name">account.move.search.glosa.prioritaria</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="l10n_cl_fe.view_account_invoice_filter"/>
        <field name="arch" type="xml">
        <xpath expr="//search/field[1]" position="before">
            <field name="glosa" string="Glosa"/>
        </xpath>
        </field>
    </record>  

       <!-- Acción para restringir la vista del boton para volver a borrador --> 
    <record id="restrict_button_draft_to_admin" model="ir.ui.view">
        <field name="name">account.move.form.restrict.draft</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">            
            <!-- Ubicamos el botón button_draft -->
            <button name="button_draft" position="attributes">
                <!-- Establecemos que solo el grupo group_admin pueda verlo -->
                <attribute name="groups">parches_insumar.group_admin</attribute>
            </button>
            
        </field>
    </record>

        <!-- Acción de ventana para mostrar solo facturas con reparo -->
    <record id="action_show_reparos" model="ir.actions.act_window">
        <field name="name">Facturas con Reparos</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('sii_result','=','reparo')]</field>
        <field name="context">{'search_default_sii_result': 'reparo'}</field>
        <field name="help">Mostrando facturas con sii_result = reparo</field>
    </record>

</odoo>
